Feature: Target Product Search


@when('I search for "{product}"')
def step_impl(context, product):
    search_box = context.driver.find_element(By.ID, "search")
    search_box.send_keys(product)
    search_box.send_keys(Keys.ENTER)


@given("I open the Target Circle page")
def step_impl(context):
    context.driver.get("https://www.target.com/circle")


@then("I should see exactly 2 storycards displayed")
def step_impl(context):
    cards = context.driver.find_elements(By.CSS_SELECTOR, "[data-test='story-card']")
    assert len(cards) == 2, f"Expected 2 cards, found {len(cards)}"

    @when("I click on the first product result")
    def step_impl(context):
        first_item = context.driver.find_element(By.CSS_SELECTOR, "[data-test='product-card']")
        first_item.click()

    @when("I add the product to the cart")
    def step_impl(context):
        add_button = context.driver.find_element(By.CSS_SELECTOR, "[data-test='add-to-cart-button']")
        add_button.click()

    @then("the cart should contain at least 1 item")
    def step_impl(context):
        cart_count = context.driver.find_element(By.CSS_SELECTOR, "[data-test='cart-count']").text
        assert int(cart_count) > 0
